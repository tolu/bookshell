{
  "name": "bookshell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test 'lib/**/*.test.ts'",
    "test:e2e": "playwright test",
    "preview": "npm run build && next start",
    "slides:dev": "slidev slides/slides.md --base /slides/ --port 3030 --open",
    "slides:build": "slidev build slides/slides.md --base /slides/ --out ../public/slides",
    "prebuild": "npm run slides:build"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@vercel/blob": "^2.4.0",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@slidev/cli": "^52.0.0",
    "@slidev/theme-seriph": "^0.25.0",
    "@slidev/types": "^52.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.0",
    "mermaid": "^11.4.0",
    "typescript": "^5.9.3"
  }
}
