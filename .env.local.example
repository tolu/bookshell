# Copy this file to .env.local and fill in.

# Gemini API key for /generate.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: shared password that gates /generate, /api/generate, and
# /api/save-artifact. If unset, the gate is OFF (useful for local dev).
# Set this on Vercel before sharing the deployed URL so random visitors
# can't burn through your Gemini credits. Rotate by changing the value;
# existing unlock cookies invalidate on next request.
GENERATE_PASSWORD=

# Blob on vercel for writing generated artifacts
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
